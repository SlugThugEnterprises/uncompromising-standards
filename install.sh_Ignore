#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

CLAUDE_DIR="$HOME/.claude"
CLAUDE_SETTINGS_FILE="$CLAUDE_DIR/settings.json"
CLAUDE_HOOK_COMMAND="$SCRIPT_DIR/hooks/pre-write.sh"

OPENCODE_CONFIG_DIR="$HOME/.config/opencode"
OPENCODE_CONFIG_FILE="$OPENCODE_CONFIG_DIR/opencode.json"
OPENCODE_PLUGIN_DIR="$OPENCODE_CONFIG_DIR/plugins"
OPENCODE_PLUGIN_FILE="$OPENCODE_PLUGIN_DIR/uncompromising-standards.js"
OPENCODE_PLUGIN_TEMPLATE="$SCRIPT_DIR/integrations/opencode/uncompromising-standards.js"

backup_file() {
    local file_path="$1"

    if [[ -f "$file_path" ]]; then
        cp "$file_path" "$file_path.backup"
    fi
}

install_claude_code() {
    local hook_json=""

    mkdir -p "$CLAUDE_DIR"
    hook_json=$(jq -n \
        --arg command "$CLAUDE_HOOK_COMMAND" \
        '{matcher: "Write", hooks: [{type: "command", command: $command}]}')

    if [[ ! -f "$CLAUDE_SETTINGS_FILE" ]]; then
        jq -n --argjson hook "$hook_json" '{hooks: {PreToolUse: [$hook]}}' > "$CLAUDE_SETTINGS_FILE"
        echo "Created $CLAUDE_SETTINGS_FILE"
        return
    fi

    backup_file "$CLAUDE_SETTINGS_FILE"

    jq \
        --arg command "$CLAUDE_HOOK_COMMAND" \
        --argjson hook "$hook_json" \
        '
        .hooks = (.hooks // {}) |
        .hooks.PreToolUse = (
            (.hooks.PreToolUse // [])
            | if any(.[]?; .matcher == "Write" and any(.hooks[]?; .type == "command" and .command == $command))
              then .
              else . + [$hook]
              end
        )
        ' \
        "$CLAUDE_SETTINGS_FILE" > "$CLAUDE_SETTINGS_FILE.tmp"

    mv "$CLAUDE_SETTINGS_FILE.tmp" "$CLAUDE_SETTINGS_FILE"
    echo "Updated $CLAUDE_SETTINGS_FILE"
}

ensure_opencode_config() {
    mkdir -p "$OPENCODE_CONFIG_DIR"

    if [[ ! -f "$OPENCODE_CONFIG_FILE" ]]; then
        jq -n '{"$schema": "https://opencode.ai/config.json"}' > "$OPENCODE_CONFIG_FILE"
        echo "Created $OPENCODE_CONFIG_FILE"
    fi
}

render_opencode_plugin() {
    mkdir -p "$OPENCODE_PLUGIN_DIR"
    backup_file "$OPENCODE_PLUGIN_FILE"

    sed "s|__UNCOMPROMISING_STANDARDS_ROOT__|$SCRIPT_DIR|g" \
        "$OPENCODE_PLUGIN_TEMPLATE" > "$OPENCODE_PLUGIN_FILE"

    echo "Installed $OPENCODE_PLUGIN_FILE"
}

main() {
    if ! command -v jq >/dev/null 2>&1; then
        echo "Error: jq is required but not installed"
        exit 1
    fi

    if [[ ! -x "$CLAUDE_HOOK_COMMAND" ]]; then
        chmod +x "$CLAUDE_HOOK_COMMAND"
    fi

    echo "Uncompromising Standards Installer"
    echo "=================================="
    echo ""

    install_claude_code
    ensure_opencode_config
    render_opencode_plugin

    echo ""
    echo "Installation complete."
    echo ""
    echo "Claude Code:"
    echo "  Hook registered in $CLAUDE_SETTINGS_FILE"
    echo "  Command: $CLAUDE_HOOK_COMMAND"
    echo ""
    echo "OpenCode:"
    echo "  Config:  $OPENCODE_CONFIG_FILE"
    echo "  Plugin:  $OPENCODE_PLUGIN_FILE"
    echo ""
    echo "Restart Claude Code and OpenCode so they pick up the new integration."
}

main "$@"
