{
  "name": "uncompromising-standards",
  "version": "2.1.0",
  "description": "Code so good you could trust it with your friend's mom's life. Mandatory enforcement mode - AI agents cannot bypass quality checks. Allows idiomatic unwrap/expect in tests.",
  "author": "SlugThugEnterprises",
  "license": "MIT",
  "homepage": "https://github.com/SlugThugEnterprises/uncompromising-standards",
  "enforcement_mode": "mandatory",
  "commands": [
    {
      "name": "check-rust",
      "description": "Enforce uncompromising Rust standards",
      "path": "commands/check-rust.md"
    },
    {
      "name": "check-go",
      "description": "Enforce uncompromising Go standards",
      "path": "commands/check-go.md"
    },
    {
      "name": "check-python",
      "description": "Enforce uncompromising Python standards",
      "path": "commands/check-python.md"
    },
    {
      "name": "check-ruby",
      "description": "Enforce uncompromising Ruby standards",
      "path": "commands/check-ruby.md"
    },
    {
      "name": "check-js",
      "description": "Enforce uncompromising JavaScript/TypeScript standards",
      "path": "commands/check-js.md"
    },
    {
      "name": "check-bash",
      "description": "Enforce uncompromising Bash standards",
      "path": "commands/check-bash.md"
    },
    {
      "name": "check-sql",
      "description": "Enforce uncompromising SQL standards",
      "path": "commands/check-sql.md"
    },
    {
      "name": "check-docs",
      "description": "Enforce uncompromising documentation standards",
      "path": "commands/check-docs.md"
    },
    {
      "name": "check-all",
      "description": "Enforce standards across all supported languages",
      "path": "commands/check-all.md"
    }
  ],
  "hooks": {
    "pre-write": {
      "script": "hooks/pre-write.sh",
      "blocking": true,
      "description": "Validates code BEFORE writing - blocks bad code"
    },
    "post-write": {
      "script": "hooks/post-write.sh",
      "blocking": true,
      "auto_rollback": true,
      "description": "Validates code AFTER writing - reverts violations"
    },
    "pre-commit": {
      "script": "hooks/pre-commit-standards.sh",
      "blocking": true,
      "description": "Final validation before git commit"
    },
    "auto-fix": {
      "script": "hooks/auto-fix.sh",
      "enabled": true,
      "description": "Attempts automatic fixes for common violations"
    }
  },
  "config": {
    "path": "config/standards.yaml",
    "schema": {
      "global": {
        "max_file_lines": 200,
        "max_function_lines": 50,
        "allow_single_letter_vars": ["i", "j", "k", "x", "y", "z"]
      }
    }
  },
  "tags": [
    "linting",
    "quality",
    "standards",
    "static-analysis",
    "rust",
    "go",
    "python",
    "ruby",
    "javascript",
    "typescript",
    "bash",
    "sql"
  ]
}
